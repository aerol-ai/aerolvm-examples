{
  "name": "daytona-examples",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmitOnError --target es2023 --module node16 --moduleResolution node16 --esModuleInterop --skipLibCheck --outDir dist index.ts",
    "start": "node dist/index.js",
    "create-vm": "node --loader ts-node/esm create-vm/index.ts",
    "exec-command": "node --loader ts-node/esm exec-command/index.ts"
  },
  "dependencies": {
    "@daytona/sdk": "0.175.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
